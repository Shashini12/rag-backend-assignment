# Server Configuration
PORT=3000

# Vector Database (FAISS - no URL needed, runs locally)
# FAISS is used instead of Chroma/Qdrant for simplicity

# Embedding Configuration (Ollama - local, no API key)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=all-minilm

# LLM Configuration (Optional - for natural language answers)
# To enable full LLM answers, uncomment and install llama3.2
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2

# Ollama runs locally on default port
OLLAMA_HOST=http://localhost:11434

# Note: No API keys required! Everything runs locally.
